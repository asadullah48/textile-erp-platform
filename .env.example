# ─── Local PostgreSQL (Docker Compose dev) ───────────────────────────────────
POSTGRES_USER=textile_user
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=textile_erp

# ─── Backend ─────────────────────────────────────────────────────────────────
# Local dev:
DATABASE_URL=postgresql+asyncpg://textile_user:change_me_in_prod@localhost:5432/textile_erp

# Neon.tech (production — get from neon.tech dashboard):
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?ssl=require

# Optional: separate admin URL using a BYPASSRLS role (falls back to DATABASE_URL if unset)
# DATABASE_ADMIN_URL=postgresql+asyncpg://admin:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?ssl=require

SECRET_KEY=change_me_in_prod_min_32_chars_long
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ALLOWED_ORIGINS accepts a JSON array for multiple origins:
# ALLOWED_ORIGINS=["https://your-app.vercel.app","http://localhost:3000"]
ALLOWED_ORIGINS=["http://localhost:3000"]

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
